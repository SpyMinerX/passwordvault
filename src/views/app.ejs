// ─── COPY & TOAST ─────────────────────────────────────────────────────────────

async function copyPasswordInline(id) {
  try {
    const res = await fetch(`/api/items/${id}/password`);
    if (!res.ok) { showToast('Copy failed — access denied', 'error'); return; }
    const { password } = await res.json();
    copyText(password || '', 'Password');
  } catch {
    showToast('Copy failed', 'error');
  }
}

function copyText(text, label) {
  if (text === undefined || text === null) return;
  navigator.clipboard.writeText(text)
    .then(() => showToast(`${label} copied`))
    .catch(() => showToast('Copy failed — clipboard unavailable', 'error'));
}

let _toastTimer = null;
function showToast(msg, type) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show ' + (type === 'error' ? 'toast-error' : 'toast-ok');
  if (_toastTimer) clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => {
    el.className = 'toast';
    _toastTimer = null;
  }, 2200);
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

async function openAuditLog(mode, id, name) {
  state.auditMode  = mode || 'full';
  state.auditItemId = id || null;
  state.auditOffset = 0;
  state.auditEntries = [];

  document.getElementById('auditModalTitle').textContent = mode === 'item' ? `History — ${name}` : 'Audit Log';
  document.getElementById('auditFilterRow').style.display = mode === 'item' ? 'none' : '';
  if (document.getElementById('auditFilter')) document.getElementById('auditFilter').value = '';
  document.getElementById('auditBody').innerHTML = '';
  document.getElementById('auditLoading').style.display = '';
  document.getElementById('auditEmpty').style.display = 'none';
  openModal('auditModal');
  await fetchAuditEntries();
}

async function fetchAuditEntries() {
  document.getElementById('auditLoading').style.display = '';
  document.getElementById('auditEmpty').style.display = 'none';
  try {
    const url = state.auditMode === 'item'
      ? `/api/audit/item/${state.auditItemId}`
      : `/api/audit?limit=${state.auditLimit}&offset=${state.auditOffset}`;

    const res = await fetch(url);
    document.getElementById('auditLoading').style.display = 'none';

    if (!res.ok) {
      const d = await res.json();
      document.getElementById('auditEmpty').textContent = d.error || 'Access denied';
      document.getElementById('auditEmpty').style.display = '';
      return;
    }

    const data = await res.json();
    state.auditEntries = data.entries || [];
    state.auditTotal   = data.total  || state.auditEntries.length;
  } catch {
    document.getElementById('auditLoading').style.display = 'none';
    document.getElementById('auditEmpty').textContent = 'Failed to load audit log';
    document.getElementById('auditEmpty').style.display = '';
  }
  renderAuditEntries();
}

const AUDIT_ACTION_META = {
  reveal_password: { label: 'Reveal password',  css: 'audit-action-reveal', icon: '👁'  },
  reveal_notes:    { label: 'Reveal notes',      css: 'audit-action-reveal', icon: '📝' },
  create_item:     { label: 'Created item',      css: 'audit-action-create', icon: '➕' },
  edit_item:       { label: 'Edited item',       css: 'audit-action-edit',   icon: '✏'  },
  delete_item:     { label: 'Deleted item',      css: 'audit-action-delete', icon: '🗑' },
  create_folder:   { label: 'Created folder',    css: 'audit-action-create', icon: '📁' },
  rename_folder:   { label: 'Renamed folder',    css: 'audit-action-edit',   icon: '📁' },
  delete_folder:   { label: 'Deleted folder',    css: 'audit-action-delete', icon: '🗑' },
};

function renderAuditEntries() {
  const filter  = document.getElementById('auditFilter')?.value || '';
  const entries = filter ? state.auditEntries.filter(e => e.action === filter) : state.auditEntries;

  const tbody = document.getElementById('auditBody');
  tbody.innerHTML = '';

  if (entries.length === 0) {
    document.getElementById('auditEmpty').textContent = filter ? 'No entries match this filter' : 'No audit entries yet';
    document.getElementById('auditEmpty').style.display = '';
    return;
  }
  document.getElementById('auditEmpty').style.display = 'none';

  for (const e of entries) {
    const tr  = document.createElement('tr');
    const ts  = new Date(e.timestamp).toLocaleString(undefined, { dateStyle: 'short', timeStyle: 'medium' });
    const meta = AUDIT_ACTION_META[e.action] || { label: e.action, css: '', icon: '' };
    tr.innerHTML = `
      <td style="white-space:nowrap;color:var(--muted)">${escHtml(ts)}</td>
      <td style="font-weight:500">${escHtml(e.actor)}</td>
      <td><span class="audit-action ${meta.css}">${meta.icon} ${escHtml(meta.label)}</span></td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${escHtml(e.resource_name||'')}">${escHtml(e.resource_name || e.resource_id || '—')}</td>
      <td style="color:var(--muted);font-size:0.75rem">${escHtml(e.ip || '—')}</td>
    `;
    tbody.appendChild(tr);
  }

  const pageInfo = document.getElementById('auditPageInfo');
  if (state.auditMode === 'full') {
    const end = state.auditOffset + state.auditEntries.length;
    pageInfo.textContent = `${state.auditOffset + 1}–${end} of ${state.auditTotal}`;
    document.getElementById('auditPrevBtn').disabled = state.auditOffset === 0;
    document.getElementById('auditNextBtn').disabled = end >= state.auditTotal;
  } else {
    pageInfo.textContent = `${entries.length} ${entries.length === 1 ? 'entry' : 'entries'}`;
    document.getElementById('auditPrevBtn').disabled = true;
    document.getElementById('auditNextBtn').disabled = true;
  }
  document.getElementById('auditCount').textContent = filter ? `(${entries.length} shown)` : '';
}

async function auditPrev() {
  if (state.auditOffset === 0) return;
  state.auditOffset = Math.max(0, state.auditOffset - state.auditLimit);
  await fetchAuditEntries();
}

async function auditNext() {
  state.auditOffset += state.auditLimit;
  await fetchAuditEntries();
}

async function openItemHistory() {
  const item = state.selectedItem;
  if (!item) return;
  await openAuditLog('item', item.id, item.name);
}

// ─── DEBUG (GLOBAL_ADMIN only — browser console) ──────────────────────────────
window.__debug = (() => {
  let _pending = null;
  return {
    listRootFolders() {
      const roots = state.treeData;
      if (!roots.length) { console.log('[debug] No root folders in tree'); return; }
      console.table(roots.map(n => ({ name: n.name, id: n.id, yourLevel: n.userLevel })));
    },
    async deleteRootFolder(nameOrId) {
      const node = state.treeData.find(n => n.id === nameOrId || n.name === nameOrId);
      if (!node) {
        console.warn('[debug] Root folder not found. Call __debug.listRootFolders() to see available ones.');
        return;
      }
      console.warn(
        `%c[debug] About to permanently delete root folder "${node.name}" (${node.id}) and ALL its contents.\n` +
        `Call __debug.confirm() within 10 seconds to proceed.`,
        'color:#f59e0b;font-weight:bold'
      );
      _pending = { id: node.id, name: node.name, expires: Date.now() + 10000 };
    },
    async confirm() {
      if (!_pending || Date.now() > _pending.expires) {
        console.error('[debug] No pending deletion or confirmation window expired. Call deleteRootFolder() again.');
        _pending = null;
        return;
      }
      const { id, name } = _pending;
      _pending = null;
      const res = await fetch(`/api/folders/debug/root/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (res.ok) {
        console.log(`%c[debug] Root folder "${name}" deleted.`, 'color:#22c55e;font-weight:bold');
        if (state.folderId === id) {
          state.folderId = null;
          document.getElementById('contentActions').style.display = 'none';
          document.getElementById('breadcrumb').textContent = 'Select a folder';
          document.getElementById('contentScroll').innerHTML =
            '<div class="placeholder"><p style="color:var(--muted)">Select a folder to view its contents</p></div>';
          clearDetailPanel();
        }
        await loadTree();
      } else {
        console.error('[debug] Failed:', data.error);
      }
    },
  };
})();

// ─── MOBILE TREE ─────────────────────────────────────────────────────────────

function toggleMobileTree() {
  const panel = document.querySelector('.tree-panel');
  const overlay = document.getElementById('treeOverlay');
  const open = panel.classList.contains('mobile-open');
  panel.classList.toggle('mobile-open', !open);
  overlay.classList.toggle('visible', !open);
}

function closeMobileTree() {
  document.querySelector('.tree-panel').classList.remove('mobile-open');
  document.getElementById('treeOverlay').classList.remove('visible');
}

// ─── SERVICE WORKER REGISTRATION ──────────────────────────────────────────────

if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').catch(() => {});
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
updateThemeIcon();
loadTree();
</script>

          <option value="">All actions</option>
          <option value="reveal_password">Reveals: password</option>
          <option value="reveal_notes">Reveals: notes</option>
          <option value="create_item">Created items</option>
          <option value="edit_item">Edited items</option>
          <option value="delete_item">Deleted items</option>

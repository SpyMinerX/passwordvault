HOST_PORT=3000

# Name of the root folder created automatically on first startup
ROOT_FOLDER_NAME=FFManching

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-64-char-hex-string

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Keep this safe — losing it means losing all data.
MASTER_KEY=change-this-to-a-random-64-char-hex-string

# LDAP / Active Directory
LDAP_URL=ldaps://your-dc.corp.com:636
LDAP_BIND_DN=CN=svc-ldap,OU=ServiceAccounts,DC=corp,DC=com
LDAP_BIND_CREDENTIALS=service-account-password
LDAP_SEARCH_BASE=OU=Users,DC=corp,DC=com
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# Optional: restrict login to members of this group (full DN)
# Leave empty to allow all LDAP users
LDAP_ALLOWED_GROUP=

# Optional: grant permanent admin access everywhere, bypassing all ACL checks.
# Can be either a plain username (sAMAccountName) OR a full group DN — both are checked.
# Examples:
#   GLOBAL_ADMIN=vince
#   GLOBAL_ADMIN=CN=IT-Admins,OU=Groups,DC=corp,DC=com
# Leave empty to disable.
GLOBAL_ADMIN=

# Optional: emergency master password for non-LDAP admin access
# When set, entering this password on the login page (with any username)
# grants full admin access to ALL folders and items, bypassing all ACL checks.
# Leave empty to disable. Keep this secret — it overrides all permissions.
EMERGENCY_PASSWORD=
